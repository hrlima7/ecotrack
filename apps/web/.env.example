# EcoTrack Web — Variaveis de Ambiente
# Copie para .env.local e preencha os valores

# ─── URL da API backend ──────────────────────────────────────────────────
# Local: http://localhost:3001
# Producao Railway: https://ecotrack-api.up.railway.app
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ─── Mapbox GL JS — token publico (opcional) ───────────────────────────
# O rastreamento usa Leaflet + OpenStreetMap por padrao (sem chave).
# Mapbox e usado apenas se o token estiver configurado.
# Crie em: https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=
