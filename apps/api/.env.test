# EcoTrack API — Variáveis de ambiente para testes (vitest)
# Usa o mesmo banco de dev. Os testes executam TRUNCATE CASCADE entre cada suite.
# Para isolar completamente, crie um banco ecotrack_test e atualize a URL.

DATABASE_URL="postgresql://ecotrack:senha@localhost:5432/ecotrack_dev"
JWT_SECRET="test-jwt-secret-com-pelo-menos-32-caracteres-para-passar"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
NODE_ENV=test
LOG_LEVEL=silent
ALLOWED_ORIGINS="http://localhost:3000"
