# EcoTrack API — Variaveis de Ambiente
# Copie para .env e preencha os valores

# ─── Servidor ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Banco de dados (PostgreSQL) ─────────────────────────────────────────
DATABASE_URL="postgresql://ecotrack:senha@localhost:5432/ecotrack_dev"

# ─── Redis (filas BullMQ + rate limit distribuido) ──────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ────────────────────────────────────────────────────────────────
# Em PROD gere com: openssl rand -base64 64
JWT_SECRET="troque-por-uma-string-aleatoria-de-pelo-menos-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── CORS ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000"

# ─── URL publica do frontend (usado em links de email) ─────────────────
WEB_BASE_URL="http://localhost:3000"

# ─── SMTP / Email transacional ──────────────────────────────────────────
# Em DEV: deixar SMTP_HOST vazio — emails sao logados, nao enviados
# Em PROD: configurar SMTP real (Resend, SendGrid, AWS SES, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EcoTrack <no-reply@ecotrack.app>"

# ─── SINIR — Integracao MTR oficial ─────────────────────────────────────
# mock = gera numero local | real = integra webservice oficial (Fase 2)
SINIR_MODE=mock
SINIR_API_URL=
SINIR_USERNAME=
SINIR_PASSWORD=

# ─── Armazenamento de PDFs (Fase 2) ─────────────────────────────────────
# STORAGE_BUCKET="ecotrack-mtr-pdfs"
# STORAGE_REGION="sa-east-1"
